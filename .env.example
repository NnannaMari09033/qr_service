# Django
DJANGO_SECRET_KEY=replace-with-output-of-secrets.token_urlsafe(50)
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — use either DATABASE_URL OR the discrete DB_* vars
DATABASE_URL=postgres://user:password@localhost:5432/qr_service
# DB_NAME=qr_service
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

